APP_NAME=Essay Pilot
# Localda shu bo'ladi. Render'da RENDER_EXTERNAL_URL avtomatik ishlatiladi.
APP_URL=http://127.0.0.1:8000

DATABASE_PATH=data/essay_pilot_clean.db
UPLOADS_DIR=uploads

DEFAULT_FREE_LIMIT=5
REFERRAL_BONUS=2

# OCR: auto | paddleocr | gemini | tesseract
OCR_PROVIDER=auto
PADDLE_OCR_LANG=en
PADDLE_OCR_DEVICE=cpu

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_OCR_MODEL=gemini-2.5-flash
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash

TELEGRAM_BOT_TOKEN=
RUN_BOT_WITH_WEB=true
TELEGRAM_BOT_MODE=polling
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
ALLOW_DEMO_AUTH=true

ADMIN_TELEGRAM_IDS=
ADMIN_SECRET=change-me
PAYMENT_CARD=
PAYMENT_CARD_HOLDER=
PAYMENT_ADMIN_USERNAME=
